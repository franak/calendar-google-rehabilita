# Configuración del servidor Node.js
# Copia este archivo como ".env" (sin el .example) y rellena los valores

# Puerto del servidor Express
PORT=8000

# Intervalo de sincronización del ICS desde Google Calendar (en minutos)
SYNC_INTERVAL_MINUTES=30

# URL del ICS público desde Google Calendar
# Obtén esta URL en tu calendario: Configuración > Calendario > Compartir > "Dirección secreta en formato iCal"
# Ejemplo:
# ICS_SOURCE_URL=https://calendar.google.com/calendar/ical/tu-calendario%40group.calendar.google.com/public/basic.ics
ICS_SOURCE_URL=https://calendar.google.com/calendar/ical/179a497285bff3a1e40cf1c18b60b7680ef3668c57ab50692387f957a1c9f7f6%40group.calendar.google.com/public/basic.ics

# Nivel de logs (info, debug, error)
LOG_LEVEL=info

# Entorno (production, development)
NODE_ENV=production

# Configuración SMTP para notificaciones por email (opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-app-password
# SMTP_FROM=tu-email@gmail.com
# SMTP_SECURE=false


# URL de la hoja de Google Sheets en formato CSV
SHEET_CSV_URL=
